DJANGO_ENV=development
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
DJANGO_TIME_ZONE=Asia/Kolkata

# Set this to a PostgreSQL URL when running the real Tier A local stack.
# Example:
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/business_hub

REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

OTEL_ENABLED=false
OTEL_SERVICE_NAME=business-hub-backend
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# Optional transitional Firebase auth/bootstrap integration.
# FIREBASE_SERVICE_ACCOUNT_PATH=../../service-account.json
