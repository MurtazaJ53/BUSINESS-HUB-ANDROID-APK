rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 0. HELPERS ---
    
    function auth() { return request.auth != null; }
    
    function isMember(shopId) {
      return auth() && exists(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid));
    }
    
    function isAdmin(shopId) {
      return isMember(shopId) && get(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid)).data.role == 'admin';
    }

    // Granular permission check - Single return expression version
    function can(shopId, module, action) {
      return auth() && (
        (request.auth.token.get('shopId', '') == shopId && 
         module in request.auth.token.get('perms', {}) && 
         request.auth.token.perms[module].get(action, null) != null) ||
        (get(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid)).data.role == 'admin') ||
        (get(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid)).data.get('permissions', {}).get(module, {}).get(action, false) == true) ||
        (get(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid)).data.get('permissions', {}).get(module, {}).get(action, false) is map && 
         get(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid)).data.get('permissions', {}).get(module, {}).get(action, false).max != null)
      );
    }

    // Validate 'override_price' discount limits - Single return expression version
    function isValidDiscount(shopId, discountVal) {
      return discountVal <= 0 || 
             (get(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid)).data.role == 'admin') ||
             (request.auth.token.get('shopId', '') == shopId && 
              'sales' in request.auth.token.get('perms', {}) && 
              'override_price' in request.auth.token.perms.sales &&
              (request.auth.token.perms.sales.override_price == true || 
               (request.auth.token.perms.sales.override_price is map && 
                request.auth.token.perms.sales.override_price.max != null && 
                discountVal <= request.auth.token.perms.sales.override_price.max))) ||
             (get(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid)).data.get('permissions', {}).get('sales', {}).get('override_price', false) == true ||
              (get(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid)).data.get('permissions', {}).get('sales', {}).get('override_price', false) is map &&
               get(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid)).data.get('permissions', {}).get('sales', {}).get('override_price', false).max != null &&
               discountVal <= get(/databases/$(database)/documents/shops/$(shopId)/staff/$(request.auth.uid)).data.get('permissions', {}).get('sales', {}).get('override_price', false).max));
    }

    // --- 1. SHOP HIERARCHY ---

    match /shops/{shopId} {
      allow read: if isMember(shopId) || (auth() && resource.data.ownerId == request.auth.uid);
      allow create: if auth() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAdmin(shopId) || (auth() && resource.data.ownerId == request.auth.uid);
      allow delete: if auth() && resource.data.ownerId == request.auth.uid;

      // Inventory
      match /inventory/{item} {
        allow read: if can(shopId, 'inventory', 'view');
        allow create: if can(shopId, 'inventory', 'create');
        allow update: if can(shopId, 'inventory', 'edit') && (request.resource.data.get('stock', null) == null || request.resource.data.stock >= 0);
        allow delete: if can(shopId, 'inventory', 'delete');
      }
      
      // Cost Data
      match /inventory_private/{item} {
        allow read: if can(shopId, 'inventory', 'view_cost');
        allow write: if isAdmin(shopId);
      }
      
      // Sales
      match /sales/{sale} {
        allow read: if can(shopId, 'sales', 'view');
        allow create: if can(shopId, 'sales', 'create') && isValidDiscount(shopId, request.resource.data.get('discount', 0));
        allow update: if isAdmin(shopId);
        allow delete: if can(shopId, 'sales', 'void_sale');
      }
      
      // Customers
      match /customers/{cust} {
        allow read: if can(shopId, 'customers', 'view');
        allow write: if can(shopId, 'customers', 'edit') || can(shopId, 'customers', 'create');
        allow delete: if can(shopId, 'customers', 'delete');
      }

      // Expenses
      match /expenses/{exp} {
        allow read: if can(shopId, 'expenses', 'view');
        allow create: if can(shopId, 'expenses', 'create');
        allow delete: if can(shopId, 'expenses', 'delete');
      }

      // Staff (Split Write: Self-update vs Admin)
      match /staff/{member} {
        allow read: if isMember(shopId) || can(shopId, 'team', 'view') || (auth() && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid);
        allow write: if isAdmin(shopId) || (auth() && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid);
      }
      
      match /staff_private/{member} {
        allow read, write: if isAdmin(shopId);
      }

      // Attendance
      match /attendance/{at} {
        allow read: if isMember(shopId);
        allow write: if isAdmin(shopId) || (auth() && request.auth.uid == request.resource.data.staffId && at.startsWith(request.auth.uid));
      }

      // Invitations
      match /invitations/{invite} {
        allow read, write: if isAdmin(shopId);
      }

      // Private Vault (Blocked for read, only admins can write auth via client if needed)
      match /private/auth {
        allow read: if false;
        allow write: if isAdmin(shopId);
      }
      match /private/{doc=**} {
        allow read, write: if false; 
      }
    }

    // --- 2. GLOBAL USER PROFILES ---

    match /users/{userId} {
      allow read: if auth();
      allow write: if auth() && request.auth.uid == userId;
    }
  }
}
